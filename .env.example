# Database (ParadeDB with pgvector + pg_search)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/agentic_rag
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/agentic_rag

# Redis (Redis Stack with RediSearch)
REDIS_URL=redis://localhost:6379

# JWT Auth
SECRET_KEY=change-me-to-a-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Anthropic (LLM calls)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Cohere (reranking)
COHERE_API_KEY=...
COHERE_RERANK_MODEL=rerank-v3.5

# LlamaParse (document parsing)
LLAMA_CLOUD_API_KEY=llx-...
